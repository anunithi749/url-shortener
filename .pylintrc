[MASTER]
disable=
    missing-module-docstring,
    missing-function-docstring,
    missing-class-docstring,
    line-too-long,
    too-many-arguments,
    unused-import,

[FORMAT]
max-line-length=100

[DESIGN]
max-attributes=10
max-arguments=6

[MESSAGES CONTROL]
disable=
    C0111,
    W0613,
    W0614,
